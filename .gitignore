# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# bot scripts — runtime data, jangan di-commit
/scripts/data/dikti-cache.json
/scripts/data/sent-ids.json
/scripts/data/wa-session/
.env.bot

# PDFs — downloaded at runtime by download-*-pdfs.mjs scripts, not in git
/public/pdfs/bima/*.pdf
/public/pdfs/hiliriset/*.pdf
/public/pdfs/brin/*.pdf
